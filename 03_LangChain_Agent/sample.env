# .env 파일 - Kitri LangChain 강의용 OPENAI_API_KEY
OPENAI_API_KEY=sk**************************************
GOOGLE_API_KEY=AI****************************************
TAVILY_API_KEY=tvly**************************************

# Notion API 설정
NOTION_API_KEY=ntn_***************************************
NOTION_PAGE_ID=26***************************************

# LangSmith 설정 (선택적 - API 키가 있을 때만 활성화)
# LangSmith API 키 발급: https://smith.langchain.com → Settings → API Keys → Create API Key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=LangChain_V1